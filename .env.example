# Copy to .env for local development. See docs/production-migration-plan.md.

# ── API / DynamoDB (server) ──────────────────────────────────────────────
STAGE=local
AUTH_MODE=local                       # local = trust dev token; cognito = verify JWT
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
TABLE_PREFIX=atiom-leave-local
CORS_ORIGIN=http://localhost:3000
PORT=3100
APP_URL=http://localhost:3000        # used in outbound email bodies

# ── S3 attachments (server) ──────────────────────────────────────────────
# Local = MinIO (docker compose). In AWS leave S3_ENDPOINT unset → real S3.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=atiom-leave-local-attachments
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Email (server) ───────────────────────────────────────────────────────
# console = log to stdout (default) · smtp = Mailpit (docker) · ses = AWS (prod)
EMAIL_MODE=smtp
EMAIL_FROM=atiom-leave@example.com
SMTP_HOST=localhost
SMTP_PORT=1025

# ── Web (client) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3100
VITE_AUTH_MODE=local                  # local | cognito

# ── Cognito (only when AUTH_MODE/VITE_AUTH_MODE=cognito) ──────────────────
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
# VITE_AWS_REGION=us-east-1
