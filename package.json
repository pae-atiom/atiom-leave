{
  "name": "atiom-leave",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#shared/*": "./shared/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "api:tables": "bun run api/scripts/createTables.ts",
    "api:bucket": "bun run api/scripts/createBucket.ts",
    "api:seed": "bun run api/scripts/seed.ts",
    "api:seed:cognito": "bun run api/scripts/seedCognito.ts",
    "api:dev": "bun run --watch api/src/dev-server.ts",
    "local:setup": "bun run api/scripts/createTables.ts && bun run api/scripts/createBucket.ts && bun run api/scripts/seed.ts",
    "local:reset": "bun run api/scripts/createTables.ts && bun run api/scripts/createBucket.ts && bun run api/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.717.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-ses": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "aws-amplify": "^6.10.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.545.0",
    "nodemailer": "^9.0.1",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.717.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-jwt-verify": "^4.0.1",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
